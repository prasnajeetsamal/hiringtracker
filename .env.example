# Copy this file to `.env` (which is gitignored) and fill in real values.
# DO NOT put real keys in this file — `.env.example` is committed to the repo.

# ─── Anthropic / Claude ──────────────────────────────────────────────
# Server-side API key (no VITE_ prefix — never expose to the browser)
ANTHROPIC_API_KEY=sk-ant-...

# Optional: override the Claude model (default: claude-sonnet-4-5)
# ANTHROPIC_MODEL=claude-sonnet-4-5

# Optional: extended thinking ("on" | "off"). Default: on.
# CLAUDE_THINKING=on
# CLAUDE_THINKING_BUDGET=3000

# ─── Supabase ────────────────────────────────────────────────────────
# Public — exposed to the browser via Vite (safe to ship).
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOi...

# Server-only.
# SUPABASE_URL mirrors VITE_SUPABASE_URL for serverless API routes.
SUPABASE_URL=https://YOUR-PROJECT.supabase.co

# Service-role key. NEVER ship to the browser. Used by lib/supabase-admin.js
# for trusted server-side writes that bypass RLS.
SUPABASE_SERVICE_ROLE_KEY=

# Legacy HS256 secret (only needed if your Supabase project signs with HS256).
# Modern projects use asymmetric keys — leave blank.
SUPABASE_JWT_SECRET=

# Optional: set to "false" to disable backend auth checks (dev only).
# REQUIRE_AUTH=true

# ─── Email (Resend) ──────────────────────────────────────────────────
# v1.0 transactional email. Get a key at https://resend.com.
RESEND_API_KEY=
EMAIL_FROM=Slate <noreply@your-domain.com>

# Public-facing URL the app is hosted at (used in email links).
APP_URL=http://localhost:4001

# ─── Local dev ───────────────────────────────────────────────────────
NODE_ENV=development
